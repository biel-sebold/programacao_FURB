ENTRADA: codP1, numTotalP1, valorP1, codP2, numTotalP2, valorP2
SAÍDA: valor totalVendas

inteiro codP1, codP2, numTotalP1, numTotalP2;
real valorUniP1, valorUniP2, valorTotal;

leia(codP1);
leia(numTotalP1);
leia(valorUniP1);
leia(codP2);
leia(numTotalP2);
leia(valorUniP2);

ValorTotal = (numTotalP1*valorUniP1) + (numTotalP2*valorUniP2);
